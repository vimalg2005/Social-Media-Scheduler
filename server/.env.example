# MongoDB Atlas connection string
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>"

# JSON Web Token secret key for auth session signatures
JWT_SECRET="YOUR_RANDOM_SECRET_KEY"

# Zernio API Key (https://zernio.com) for real social posting OAuth flows
ZERNIO_API_KEY="sk_zernio_your_api_key"

# Google Gemini API Key for captions and Imagen prompts synthesis
GEMINI_API_KEY="AIzaSyYourGeminiApiKey"

# Leonardo AI API Key (Optional / Legacy)
LEONARDO_API_KEY="your_leonardo_api_key"

# Cloudinary configuration details for storing generated AI images
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# Backend server binding port (Optional, defaults to 3000)
PORT=3000
